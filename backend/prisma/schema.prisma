// Схема базы данных ПроЦесс CRM/BPM.
// Повторяет структуры фронтенда (задачи, юзеры, филиалы, кассы),
// но как настоящие таблицы со связями и ограничениями целостности.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id       String   @id @default(cuid())
  name     String
  inn      String
  branches Branch[]
}

model Branch {
  id            String  @id @default(cuid())
  name          String
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
  monthlyBudget Int     @default(0)
  users         User[]
  tasks         Task[]

  @@index([companyId])
}

model User {
  id           String   @id @default(cuid())
  name         String   @unique // внутренний логин/ключ (уникален)
  passwordHash String // bcrypt-хэш, никогда не пароль
  role         String // director|finance|manager|accountant|sysadmin|staff
  position     String   @default("")
  departmentId String?
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // ── Интеграция с iiko (кадры) ─ iiko как источник правды по сотрудникам.
  login              String? // логин из iiko (вход по нему), напр. "Jahongir"
  displayName        String? // ФИО из iiko для отображения
  positionCode       String  @default("") // код роли iiko (ADM, MN1, WR1…)
  iikoId             String? @unique // id сотрудника в iiko (ключ синхронизации)
  iikoDepartment     String  @default("") // подразделения/филиалы из iiko (текст)
  source             String  @default("manual") // manual | iiko
  iikoDeleted        Boolean @default(false) // удалён/уволен в iiko
  mustChangePassword Boolean @default(false) // сменить пароль при первом входе
  hireDate           String? // дата найма из iiko
  fireDate           String? // дата увольнения из iiko

  // ── Телеграм-бот чек-листов (для линейного персонала, напр. уборщиц) ─
  // HR привязывает Telegram сотрудника к филиалу заранее; бот в личке ведёт
  // сотрудника по чек-листам. telegramId — числовой id пользователя Telegram.
  // checklistBranch — id филиала из конфигурации фронтенда (строкой, без FK на
  // таблицу Branch, т.к. филиалы заданы в приложении числовыми id 1..6).
  telegramId      String? @unique
  checklistBranch String?

  createdTasks Task[]     @relation("creator")
  auditLogs    AuditLog[]

  @@index([branchId])
  @@index([role])
  @@index([login])
}

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  departmentId String
  executorId   String
  controllerId String
  createdById  String
  createdBy    User     @relation("creator", fields: [createdById], references: [id])
  phase        Int      @default(1) // 1..5
  category     String
  priority     String
  amount       Int?
  overBudget   Boolean  @default(false)
  slaDeadline  DateTime
  extra        Json? // гибкие доп. поля (JSONB)
  createdAt    DateTime @default(now())

  history  TaskHistory[]
  comments Comment[]

  @@index([branchId])
  @@index([executorId])
  @@index([controllerId])
  @@index([createdById])
  @@index([slaDeadline])
}

// Неизменяемый журнал — записи только добавляются, никогда не меняются/удаляются
model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  userId    String
  action    String // created|viewed|start|review|done|return|comment|step
  fromPhase Int?
  toPhase   Int?
  note      String?
  at        DateTime @default(now())

  @@index([taskId])
}

model Comment {
  id     String   @id @default(cuid())
  taskId String
  task   Task     @relation(fields: [taskId], references: [id])
  userId String
  text   String
  at     DateTime @default(now())

  @@index([taskId])
}

model CashReport {
  id          String    @id @default(cuid())
  branchId    String // id филиала фронтенда (без FK — как в MoneyTx/чек-листах)
  branchName  String    @default("") // название филиала (для отчётов/бота)
  date        String // YYYY-MM-DD
  userId      String
  status      String    @default("submitted") // submitted|confirmed
  // Деньги — BigInt, как в MoneyTx: Int32 (до ~2,1 млрд сум) для дневной
  // выручки в UZS даёт слишком маленький запас.
  fiscal      BigInt    @default(0)
  nonFiscal   BigInt    @default(0)
  humo        BigInt    @default(0)
  uzcard      BigInt    @default(0)
  click       BigInt    @default(0)
  payme       BigInt    @default(0)
  uzumTezkor  BigInt    @default(0)
  yandex      BigInt    @default(0)
  transfer    BigInt    @default(0)
  expenses    BigInt    @default(0)
  iiko        BigInt    @default(0)
  comment     String?
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
  confirmedBy String?

  @@unique([branchId, date]) // один отчёт на филиал в день
  @@index([branchId])
  @@index([date])
}

// Учёт и контроль денег компании (казначейство). Заменяет ручной Excel:
// приходы/расходы с типом, контрагентом, комментарием, суммой и валютой,
// филиалом. Приход с филиала (инкассация) заводится автоматически (refId —
// защита от дублей). Поля iiko* — для будущей выгрузки проводок в iiko.
model MoneyTx {
  id           String   @id @default(cuid())
  date         String // YYYY-MM-DD (операционная дата)
  direction    String // income | expense
  category     String // статья/тип (Расход Маркетинг, Хоз расходы, Уставной фонд, Приход с филиала…)
  ddsArticle   String   @default("") // статья ДДС (движение денежных средств)
  paymentType  String   @default("Наличные") // тип оплаты (Наличные, Перечисление, Карта…)
  legalEntity  String   @default("") // юр. лицо (для перечислений)
  account      String   @default("") // счёт (для перечислений)
  counterparty String   @default("") // контрагент / на что потрачено
  comment      String   @default("")
  amount       BigInt // сумма в валюте currency
  currency     String   @default("UZS") // UZS | RUB | USD | EUR
  rate         Float    @default(1) // курс валюты к суму (для UZS = 1)
  amountUzs    BigInt // amount * rate — для баланса и отчётов
  branchId     String? // id филиала (без FK: филиалы могут быть демо/реальными)
  branchName   String   @default("") // название филиала (для отчётов/истории)
  source       String   @default("manual") // manual | branch-transfer | iiko
  refId        String?  @unique // источник авто-прихода (id передачи) — идемпотентность
  iikoStatus   String   @default("none") // none | pending | posted | error
  iikoDocId    String? // id проводки/документа в iiko после выгрузки
  createdById  String?
  createdAt    DateTime @default(now())

  // ── Согласование расходов (workflow «заявка → апрув») ─────────────────────
  // approved — учитывается в балансе/отчётах; pending — заявка на согласовании
  // (в баланс не идёт); rejected — отклонена. Приходы и инкассация — approved.
  approval     String    @default("approved") // approved | pending | rejected
  approvedById String? // кто согласовал/отклонил
  approvedAt   DateTime? // когда
  rejectReason String    @default("") // причина отклонения

  @@index([date])
  @@index([direction])
  @@index([branchId])
  @@index([category])
  @@index([approval])
  @@index([branchId, date])
  @@index([approval, direction, branchId])
}

// Справочники модуля денег: типы/статьи, контрагенты, статьи ДДС, филиалы,
// юр. лица, счета, типы оплат. Пользователь пополняет их из интерфейса.
// parent — для счетов (какому юр. лицу принадлежит счёт).
model MoneyDict {
  id        String   @id @default(cuid())
  type      String // category|counterparty|ddsArticle|branch|legalEntity|account|paymentType
  name      String
  parent    String   @default("") // для account: юр. лицо-владелец
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([type, name])
  @@index([type])
}

// Регулярные (периодические) проводки: известные ежемесячные расходы —
// аренда, амортизация, зарплата и т.п. Система сама заводит движение (MoneyTx)
// раз в месяц в назначенный день, идемпотентно (refId = recur-<id>-<YYYYMM>).
model MoneyRecurring {
  id              String   @id @default(cuid())
  name            String // «Аренда Микрорайон», «Амортизация цех»…
  direction       String   @default("expense") // income | expense
  category        String
  ddsArticle      String   @default("")
  paymentType     String   @default("Наличные")
  legalEntity     String   @default("")
  account         String   @default("")
  counterparty    String   @default("")
  comment         String   @default("")
  amount          BigInt // сумма в валюте currency
  currency        String   @default("UZS")
  rate            Float    @default(1)
  branchId        String?
  branchName      String   @default("")
  dayOfMonth      Int      @default(1) // день месяца для проводки (1..28)
  startMonth      String // YYYY-MM — с какого месяца заводить
  endMonth        String   @default("") // YYYY-MM — по какой (пусто = бессрочно)
  autoApprove     Boolean  @default(true) // проводить сразу (согласовано)
  active          Boolean  @default(true)
  lastPostedMonth String   @default("") // YYYY-MM последнего заведённого месяца
  createdById     String?
  createdAt       DateTime @default(now())

  @@index([active])
}

// ── Бухгалтерия: двойная запись (Дт/Кт) ────────────────────────────────────

// План счетов (справочник бухгалтерских счетов, НСБУ Узбекистана).
// kind: active | passive | income | expense | contra — для знака сальдо в ОСВ.
model LedgerAccount {
  id        String   @id @default(cuid())
  code      String   @unique // «5010», «6710», «9420»…
  name      String // «Касса», «Административные расходы»…
  kind      String   @default("active") // active|passive|income|expense|contra
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([code])
}

// Правило авто-проводки: по направлению и статье движения денег определяет
// пару счетов Дт/Кт. Пустой debit/credit = «авто» (сторона кассы/банка по типу
// оплаты). category = "" — правило по умолчанию (fallback) для направления.
model PostingRule {
  id        String   @id @default(cuid())
  direction String // income | expense
  category  String   @default("") // статья движения ("" = по умолчанию)
  debit     String   @default("") // код счёта Дт ("" = авто)
  credit    String   @default("") // код счёта Кт ("" = авто)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([direction, category])
}

// Проводка (бухгалтерская запись двойной записи): дебет одного счёта и кредит
// другого на одну сумму. Формируется автоматически из движения денег (MoneyTx)
// по правилам PostingRule (идемпотентно, refId = mtx-<id>) либо вручную.
model Posting {
  id          String   @id @default(cuid())
  date        String // YYYY-MM-DD
  number      String   @default("") // номер документа/проводки
  debit       String // код счёта по дебету
  credit      String // код счёта по кредиту
  amount      BigInt // сумма в сумах (UZS)
  currency    String   @default("UZS")
  description String   @default("")
  legalEntity String   @default("")
  branchId    String?
  branchName  String   @default("")
  source      String   @default("manual") // manual | money-tx
  refId       String?  @unique // идемпотентность авто-проводки (mtx-<id>)
  moneyTxId   String? // связь с движением денег
  createdById String?
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([debit])
  @@index([credit])
  @@index([debit, date])
  @@index([credit, date])
  @@index([source])
}

// Журнал безопасности — кто что выгружал, кто пытался копировать
model AuditLog {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  event  String // export_csv|print|blocked_copy|delete_cash_report|login...
  detail String?
  ip     String?
  at     DateTime @default(now())

  @@index([userId])
  @@index([event])
  @@index([userId, event, ip])
  @@index([at])
}

// Сданный через бота (или приложение) чек-лист смены. Хранит отметки и
// ссылки на фото (file_id Telegram) для санитарного обхода и открытия/закрытия.
model ShiftChecklistRun {
  id         String   @id @default(cuid())
  branchId   String? // филиал (id из конфигурации, строкой)
  kind       String // sanitary | open | close | role | cleaning
  date       String // YYYY-MM-DD (Asia/Tashkent)
  slot       String? // "09:00" для почасового обхода, null для разовых
  items      Json // [{ text, needPhoto, done, photoFileId }]
  pct        Int      @default(0)
  userId     String? // кто сдал (User.id), если известен
  via        String   @default("bot") // bot | app
  // Для чек-листов по настраиваемым шаблонам (kind role|cleaning): ссылка на
  // шаблон и его заголовок/должность на момент сдачи — чтобы отчёт не зависел
  // от последующего редактирования/удаления шаблона.
  templateId String?
  title      String?
  position   String?
  createdAt  DateTime @default(now())

  @@index([branchId, date])
  @@index([kind, date])
  @@index([date])
  @@index([templateId, date])
}

// Состояние диалога бота с пользователем (черновик заполняемого чек-листа).
// Ключ — telegramId. Обновляется на каждом шаге, очищается после сдачи.
model BotSession {
  telegramId String   @id
  state      Json // { kind, slot, branchId, items:[...], awaitingPhoto }
  updatedAt  DateTime @updatedAt
}

// Конфигурация организации (одна строка, id=1): бренд, юрлица, филиалы с
// отделениями iiko и окнами чек-листов. Выносит «прибитые гвоздями» данные
// Avesto из кода — система становится настраиваемой под любую компанию.
model OrgConfig {
  id          Int      @id @default(1)
  data        Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ── Back Office владельца системы ───────────────────────────────────────────
// Реестр клиентов, покупающих систему (путь «под ключ»: у каждого клиента —
// своя установка). Ведётся владельцем (owner) и его командой продаж (vendor);
// бизнес-ролям клиента (director и т.д.) этот раздел недоступен.
model VendorClient {
  id            String    @id @default(cuid())
  name          String // название компании клиента
  contact       String    @default("") // контактное лицо
  phone         String    @default("")
  status        String    @default("lead") // lead|demo|active|paused|churned
  tariff        String    @default("") // название тарифа/пакета
  monthlyFee    BigInt    @default(0) // ежемесячная плата, сум
  deployUrl     String    @default("") // адрес установки клиента
  notes         String    @default("")
  // Мониторинг работоспособности установки клиента (только чтение /api/health;
  // никакого управления чужой системой из Back Office нет by design).
  lastCheckAt   DateTime?
  lastCheckOk   Boolean?
  lastLatencyMs Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

// Доска развития продукта: идеи и запросы функций (в т.ч. от клиентов).
model FeatureRequest {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  clientName  String   @default("") // от какого клиента пришло (свободный текст)
  status      String   @default("idea") // idea|planned|in_progress|done
  priority    String   @default("normal") // low|normal|high
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// ── Модульность продукта (управляется из Back Office владельцем) ────────────
// Флаги функций, которые владелец системы включает под потребность клиента.
// Одна строка (id=1), JSON. Пусто = модуль выключен (безопасный дефолт для
// новых установок; у Avesto включается по месту).
model ModuleConfig {
  id          Int      @id @default(1)
  data        Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// Шаблон чек-листа, настраиваемый клиентом в админке (когда модуль включён).
// kind: role — чек-лист по должности; cleaning — почасовая уборка.
model ChecklistTemplate {
  id           String   @id @default(cuid())
  kind         String // role | cleaning
  position     String   @default("") // для role: должность (произвольная строка)
  title        String
  items        Json // [{ text, needPhoto }]
  scheduleType String   @default("daily") // daily | shift | hourly
  fromHour     Int? // для hourly — начало окна
  toHour       Int? // для hourly — конец окна
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([kind])
  @@index([active])
}

// Настройка доступа по ролям (управляется сисадмином клиента в админке):
// какие разделы/отчёты видит каждая роль. Оверрайды поверх дефолтов навигации;
// пусто = поведение по умолчанию. Одна строка (id=1), JSON.
model AccessConfig {
  id          Int      @id @default(1)
  data        Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// Пороги согласования расходов (управляется директором/сисадмином в админке):
// расход не выше порога проводится сразу, выше — уходит на согласование.
// Есть переопределение по филиалам. Одна строка (id=1), JSON. По умолчанию
// порог 0 — согласования требует любой расход (прежнее поведение).
model ApprovalConfig {
  id          Int      @id @default(1)
  data        Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// Отделы и маршрутизация категорий задач (управляется директором/сисадмином в
// админке): список отделов с признаком «закрытый» и карта категория→отдел.
// Определяет видимость задач по отделам. Одна строка (id=1), JSON.
model DeptConfig {
  id          Int      @id @default(1)
  data        Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// Ставки оплаты труда по сотруднику (управляется директором/сисадмином в
// админке): режим (оклад/почасовой) и сумма. Одна строка (id=1), JSON вида
// { rates: { userId: { mode: "salary"|"hourly", amount: number } } }. Ставок в
// iiko-API нет, поэтому задаются в системе.
model PayrollConfig {
  id          Int      @id @default(1)
  data        Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

model FoodCostConfig {
  id          Int      @id @default(1)
  data        Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// Лёгкий менеджер задач (доска/канбан): быстрые задачи с исполнителем, сроком
// и приоритетом. Отдельно от формального процесса «заявок» (модель Task с
// 5 фазами и контролёром) — здесь простой статус todo/in_progress/done.
model TodoTask {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  status      String    @default("todo") // todo | in_progress | done
  priority    String    @default("normal") // low | normal | high
  important   Boolean   @default(false) // «звёздочка» — отметка важного
  assigneeId  String? // id пользователя-исполнителя (без FK: могут быть демо)
  branchId    String? // id филиала (org) — для охвата/фильтра
  dueDate     DateTime? // срок
  remindedOn  String? // YYYY-MM-DD последнего Telegram-напоминания (дедуп за день)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  doneAt      DateTime?

  @@index([status])
  @@index([assigneeId])
  @@index([branchId])
  @@index([createdById])
  @@index([dueDate])
}

model PlanEntry {
  id        String   @id @default(cuid())
  month     String // YYYY-MM
  branchId  String // id филиала (org, как в CashReport/MoneyTx)
  revenue   BigInt   @default(0) // план выручки, сум
  expense   BigInt   @default(0) // план расходов, сум (опционально)
  updatedAt DateTime @updatedAt

  @@unique([month, branchId])
  @@index([month])
}

// Помесячные данные зарплатной ведомости по сотруднику: часы (для почасовых),
// бонусы и штрафы. Ставка берётся из PayrollConfig. Одна запись на (месяц,
// сотрудник). Деньги — BigInt (сум).
model PayrollEntry {
  id        String   @id @default(cuid())
  month     String // YYYY-MM
  userId    String
  hours     Float    @default(0) // отработанные часы (для почасовых)
  bonus     BigInt   @default(0) // премии/надбавки, сум
  penalty   BigInt   @default(0) // удержания/штрафы, сум
  note      String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([month, userId])
  @@index([month])
}
