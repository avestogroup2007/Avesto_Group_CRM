// Схема базы данных ПроЦесс CRM/BPM.
// Повторяет структуры фронтенда (задачи, юзеры, филиалы, кассы),
// но как настоящие таблицы со связями и ограничениями целостности.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id       String   @id @default(cuid())
  name     String
  inn      String
  branches Branch[]
}

model Branch {
  id            String       @id @default(cuid())
  name          String
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  monthlyBudget Int          @default(0)
  users         User[]
  tasks         Task[]
  cashReports   CashReport[]

  @@index([companyId])
}

model User {
  id           String   @id @default(cuid())
  name         String   @unique // внутренний логин/ключ (уникален)
  passwordHash String // bcrypt-хэш, никогда не пароль
  role         String // director|finance|manager|accountant|sysadmin|staff
  position     String   @default("")
  departmentId String?
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // ── Интеграция с iiko (кадры) ─ iiko как источник правды по сотрудникам.
  login              String? // логин из iiko (вход по нему), напр. "Jahongir"
  displayName        String? // ФИО из iiko для отображения
  positionCode       String  @default("") // код роли iiko (ADM, MN1, WR1…)
  iikoId             String? @unique // id сотрудника в iiko (ключ синхронизации)
  iikoDepartment     String  @default("") // подразделения/филиалы из iiko (текст)
  source             String  @default("manual") // manual | iiko
  iikoDeleted        Boolean @default(false) // удалён/уволен в iiko
  mustChangePassword Boolean @default(false) // сменить пароль при первом входе
  hireDate           String? // дата найма из iiko
  fireDate           String? // дата увольнения из iiko

  createdTasks Task[]     @relation("creator")
  auditLogs    AuditLog[]

  @@index([branchId])
  @@index([role])
}

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  departmentId String
  executorId   String
  controllerId String
  createdById  String
  createdBy    User     @relation("creator", fields: [createdById], references: [id])
  phase        Int      @default(1) // 1..5
  category     String
  priority     String
  amount       Int?
  overBudget   Boolean  @default(false)
  slaDeadline  DateTime
  extra        Json? // гибкие доп. поля (JSONB)
  createdAt    DateTime @default(now())

  history  TaskHistory[]
  comments Comment[]

  @@index([branchId])
  @@index([executorId])
  @@index([controllerId])
  @@index([createdById])
}

// Неизменяемый журнал — записи только добавляются, никогда не меняются/удаляются
model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  userId    String
  action    String // created|viewed|start|review|done|return|comment|step
  fromPhase Int?
  toPhase   Int?
  note      String?
  at        DateTime @default(now())

  @@index([taskId])
}

model Comment {
  id     String   @id @default(cuid())
  taskId String
  task   Task     @relation(fields: [taskId], references: [id])
  userId String
  text   String
  at     DateTime @default(now())

  @@index([taskId])
}

model CashReport {
  id          String    @id @default(cuid())
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id])
  date        String // YYYY-MM-DD
  userId      String
  status      String    @default("submitted") // submitted|confirmed
  fiscal      Int       @default(0)
  nonFiscal   Int       @default(0)
  humo        Int       @default(0)
  uzcard      Int       @default(0)
  click       Int       @default(0)
  payme       Int       @default(0)
  uzumTezkor  Int       @default(0)
  yandex      Int       @default(0)
  transfer    Int       @default(0)
  expenses    Int       @default(0)
  iiko        Int       @default(0)
  comment     String?
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
  confirmedBy String?

  @@unique([branchId, date]) // один отчёт на филиал в день
  @@index([branchId])
}

// Учёт и контроль денег компании (казначейство). Заменяет ручной Excel:
// приходы/расходы с типом, контрагентом, комментарием, суммой и валютой,
// филиалом. Приход с филиала (инкассация) заводится автоматически (refId —
// защита от дублей). Поля iiko* — для будущей выгрузки проводок в iiko.
model MoneyTx {
  id           String   @id @default(cuid())
  date         String // YYYY-MM-DD (операционная дата)
  direction    String // income | expense
  category     String // статья/тип (Расход Маркетинг, Хоз расходы, Уставной фонд, Приход с филиала…)
  ddsArticle   String   @default("") // статья ДДС (движение денежных средств)
  paymentType  String   @default("Наличные") // тип оплаты (Наличные, Перечисление, Карта…)
  legalEntity  String   @default("") // юр. лицо (для перечислений)
  account      String   @default("") // счёт (для перечислений)
  counterparty String   @default("") // контрагент / на что потрачено
  comment      String   @default("")
  amount       BigInt // сумма в валюте currency
  currency     String   @default("UZS") // UZS | RUB | USD | EUR
  rate         Float    @default(1) // курс валюты к суму (для UZS = 1)
  amountUzs    BigInt // amount * rate — для баланса и отчётов
  branchId     String? // id филиала (без FK: филиалы могут быть демо/реальными)
  branchName   String   @default("") // название филиала (для отчётов/истории)
  source       String   @default("manual") // manual | branch-transfer | iiko
  refId        String?  @unique // источник авто-прихода (id передачи) — идемпотентность
  iikoStatus   String   @default("none") // none | pending | posted | error
  iikoDocId    String? // id проводки/документа в iiko после выгрузки
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([direction])
  @@index([branchId])
  @@index([category])
}

// Справочники модуля денег: типы/статьи, контрагенты, статьи ДДС, филиалы,
// юр. лица, счета, типы оплат. Пользователь пополняет их из интерфейса.
// parent — для счетов (какому юр. лицу принадлежит счёт).
model MoneyDict {
  id        String   @id @default(cuid())
  type      String // category|counterparty|ddsArticle|branch|legalEntity|account|paymentType
  name      String
  parent    String   @default("") // для account: юр. лицо-владелец
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([type, name])
  @@index([type])
}

// Журнал безопасности — кто что выгружал, кто пытался копировать
model AuditLog {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  event  String // export_csv|print|blocked_copy|delete_cash_report|login...
  detail String?
  ip     String?
  at     DateTime @default(now())

  @@index([userId])
  @@index([event])
}
