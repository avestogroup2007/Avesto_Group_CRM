# ── База данных ──────────────────────────────────────────────
# Строка подключения к PostgreSQL 16
DATABASE_URL="postgresql://user:pass@localhost:5432/procystem"

# ── Аутентификация ───────────────────────────────────────────
# Длинная случайная строка (минимум 32 символа). Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="замените-на-длинную-случайную-строку-минимум-32-символа"

# ── Сервер ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Адрес фронтенда (для CORS). В проде — https://ваш-домен
FRONTEND_URL="http://localhost:5173"
# Ставить ли флаг Secure на cookie (true только под HTTPS).
# В локальной разработке по http оставьте false.
COOKIE_SECURE=false
# SameSite для cookie: strict локально; none — если фронт и бэкенд на РАЗНЫХ
# доменах (напр. github.io ↔ onrender.com). При none обязательно COOKIE_SECURE=true.
COOKIE_SAMESITE=strict

# ── iiko (iikoCloud Transport API) ─ секреты, задаются ТОЛЬКО в окружении
# хостинга (не в git). Если не задан apiLogin, /api/iiko/* вернут 503.
# Авторизация /api/v2/access_token: apiLogin + appId + clientSecret.
# IIKO_API_LOGIN="apiLogin"       # поле apiLogin
# IIKO_API_ID="appId"             # поле appId
# IIKO_CLIENT_SECRET="clientSecret"  # поле clientSecret
# IIKO_BASE_URL="https://api-ru.iiko.services"
