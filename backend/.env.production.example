# Avesto Group CRM — пример окружения бэкенда для своего сервера (avesto.group/crm).
# Скопируйте в backend/.env (или задайте переменными systemd/окружения) и
# заполните значения. НИКОГДА не коммитьте настоящий .env с секретами в git.

# ── Обязательное ──────────────────────────────────────────────────────────
# Строка подключения к PostgreSQL.
DATABASE_URL=postgresql://avesto_crm:СМЕНИТЕ_ПАРОЛЬ@127.0.0.1:5432/avesto_crm
# Секрет для подписи JWT — минимум 32 символа, сгенерируйте случайный:
#   openssl rand -base64 48
JWT_SECRET=СГЕНЕРИРУЙТЕ_ДЛИННУЮ_СЛУЧАЙНУЮ_СТРОКУ

NODE_ENV=production
PORT=3000
# Часовой пояс Узбекистана — серверные даты/время по Ташкенту (UTC+5).
TZ=Asia/Tashkent

# ── Домен и cookie (всё same-origin под avesto.group/crm) ──────────────────
# Разрешённый источник CORS = наш домен.
FRONTEND_URL=https://avesto.group
# Прод по HTTPS — cookie только Secure.
COOKIE_SECURE=true
# Same-origin (фронт и API на одном домене) → достаточно lax (безопаснее none).
COOKIE_SAMESITE=lax
# Логин владельца системы: этот аккаунт при входе получает роль owner (+ Back
# Office). Единственный безопасный способ назначить владельца.
OWNER_LOGIN=ваш_логин_из_iiko

# ── iiko (источник истины по продажам и кадрам) ───────────────────────────
# IIKO_SERVER_URL=https://ваш-хост:порт
# IIKO_SERVER_LOGIN=логин_iikoOffice
# IIKO_SERVER_PASSWORD=пароль_iikoOffice

# ── Telegram (уведомления и бот) — по желанию ─────────────────────────────
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# Внешний адрес бэкенда для setWebhook — под подпутём это домен + /crm.
# Итоговый вебхук: https://avesto.group/crm/api/telegram/webhook
# PUBLIC_BASE_URL=https://avesto.group/crm
# TELEGRAM_WEBHOOK_SECRET=...
# Адрес приложения для кнопки «Открыть CRM» (Mini App) в боте.
# PUBLIC_APP_URL=https://avesto.group/crm/
# Секрет крон-эндпоинта напоминаний о задачах (POST /api/todos-cron/remind).
# TODO_REMINDER_SECRET=...
# Топик Telegram для сигналов «Закупки и склад» (цены/остатки/движение).
# Создайте тему в супергруппе и укажите её message_thread_id.
# TELEGRAM_TOPIC_GOODS=...
# Секрет крон-эндпоинта авто-проверки закупок (POST /api/procurement-cron/check).
# PROCUREMENT_CRON_SECRET=...

# ── Прочее — по желанию ───────────────────────────────────────────────────
# SENTRY_DSN=...
# ANTHROPIC_API_KEY=...
